{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ],
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static-build"
    },
    {
      "src": "backend/**",
      "use": "@vercel/node"
    }
  ]
}
